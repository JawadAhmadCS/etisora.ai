# ============================================================
#  ETISORA CHATBOT - ENVIRONMENT VARIABLES
#  Copy this file to .env and fill in your real values
#  NEVER commit .env to GitHub or share it publicly
# ============================================================

# OPENAI (primary)
# Your OpenAI API key (starts with sk-)
OPENAI_API_KEY=your_openai_api_key_here
# Optional model override (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# GROQ (automatic backup if OpenAI fails)
GROQ_API_KEY=your_groq_api_key_here
# Optional model override (default: llama-3.1-8b-instant)
GROQ_MODEL=llama-3.1-8b-instant

# GOOGLE SHEETS
# From your Google Cloud Service Account JSON file
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"

# The ID of your Google Sheet (from the URL)
# e.g. https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# The name of the tab/sheet to write to (default: Inquiries)
GOOGLE_SHEET_TAB=Inquiries

# APP CONFIG
# Port for the chatbot server (if running via API/webhook)
PORT=3000
